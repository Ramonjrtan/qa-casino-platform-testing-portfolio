              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Bet accepted', function () { pm.expect([200,201]).to.include(pm.response.code); });",
                  "var data = pm.response.json(); if (data.betId) { pm.collectionVariables.set('betId', data.betId); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Settle Bet",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"betId\": \"bet-9001\",\n  \"result\": \"WIN\",\n  \"payout\": 12.5,\n  \"eventId\": \"settle-evt-9001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/bets/{{betId}}/settlement",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bets",
                "{{betId}}",
                "settlement"
              ]
            }
          }
        },
        {
          "name": "Void Bet",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"betId\": \"bet-9001\",\n  \"reason\": \"ROUND_CANCELLED\",\n  \"eventId\": \"void-evt-9001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/bets/{{betId}}/void",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bets",
                "{{betId}}",
                "void"
              ]
            }
          }
        }
      ]
    },
