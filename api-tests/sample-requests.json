      },
      "response_example": {
        "status": "ACTIVE",
        "sessionAction": "FORCED_LOGOUT"
      }
    },
    "auditQuery": {
      "request": {
        "from": "2026-04-01T00:00:00Z",
        "to": "2026-04-05T23:59:59Z",
        "playerId": "player-1001",
        "eventType": "TRANSACTION"
      },
      "response_example": {
        "count": 12,
        "records": [
          {
            "eventId": "aud-1001",
