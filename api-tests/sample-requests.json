        "availableBalance": 110.0
      }
    },
    "adjustment": {
      "request": {
        "playerId": "player-1001",
        "type": "REFUND",
        "amount": 10.0,
        "reasonCode": "VOID_ROUND",
        "operatorId": "qa-admin-01"
      },
      "response_example": {
        "transactionId": "txn-adj-1001",
        "status": "POSTED",
        "newBalance": 120.0
      }
    }
  },
  "betting": {
    "placeBet": {
      "request": {
        "playerId": "player-1001",
        "gameId": "slot-001",
